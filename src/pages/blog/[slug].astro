---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';
import { site } from '../../data/site';

export async function getStaticPaths() {
  const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
    (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
  );
  return posts.map((post, i) => ({
    params: { slug: post.id },
    props: { post, newerPost: posts[i - 1], olderPost: posts[i + 1] },
  }));
}

const { post, newerPost, olderPost } = Astro.props;
const { Content } = await render(post);

function formatDate(d: Date) {
  return d.toLocaleDateString('en-US', {
    month: 'long',
    day: 'numeric',
    year: 'numeric',
    timeZone: 'UTC',
  });
}

const postURL = new URL(`/blog/${post.id}`, site.brandUrl).toString();

const blogPostingSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.excerpt,
  datePublished: post.data.date.toISOString(),
  author: { '@type': 'Organization', name: site.name },
  publisher: { '@type': 'Organization', name: site.name },
  mainEntityOfPage: postURL,
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: site.brandUrl },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: new URL('/blog', site.brandUrl).toString() },
    { '@type': 'ListItem', position: 3, name: post.data.title, item: postURL },
  ],
};
---

<Base
  title={`${post.data.seoTitle ?? post.data.title} · ${site.name}`}
  description={post.data.excerpt}
  structuredData={[blogPostingSchema, breadcrumbSchema]}
>
  <article class="post section">
    <div class="container post__inner">
      <p class="tick-label" data-reveal>
        <a href="/blog" class="tick-accent">[blog]</a>
      </p>
      <h1 class="display post__title" data-reveal style="--reveal-delay: 60ms">
        {post.data.title}
      </h1>
      <p class="post__date" data-reveal style="--reveal-delay: 100ms">
        {formatDate(post.data.date)}
      </p>

      <div class="post__body prose-max" data-reveal style="--reveal-delay: 140ms">
        <Content />
      </div>

      <p class="post__foot hairline-top">
        <a href="/blog">&larr; back to all posts</a>
      </p>

      {(newerPost || olderPost) && (
        <nav class="post__nav" aria-label="More posts">
          {olderPost && (
            <a href={`/blog/${olderPost.id}`} class="post__nav-link post__nav-link--prev">
              <span class="post__nav-label">&larr; previous</span>
              <span class="post__nav-title">{olderPost.data.title}</span>
            </a>
          )}
          {newerPost && (
            <a href={`/blog/${newerPost.id}`} class="post__nav-link post__nav-link--next">
              <span class="post__nav-label">next &rarr;</span>
              <span class="post__nav-title">{newerPost.data.title}</span>
            </a>
          )}
        </nav>
      )}
    </div>
  </article>
</Base>

<style>
  .post__inner {
    max-width: 52rem;
    padding-inline: clamp(1rem, 3.25vw, 2.1rem);
  }

  .post__title {
    margin-top: 1.2rem;
    font-size: clamp(2rem, 5vw, 3rem);
  }

  .post__date {
    margin-top: 0.9rem;
    font-family: var(--font-mono);
    font-size: 0.84rem;
    color: var(--muted);
  }

  .post__body {
    margin-top: 3rem;
    max-width: none;
  }

  .post__body :global(h2) {
    margin-top: 2.2rem;
    margin-bottom: 0.8rem;
    font-size: 1.35rem;
    font-weight: 640;
    letter-spacing: -0.015em;
  }

  .post__body :global(h3) {
    margin-top: 1.9rem;
    margin-bottom: 0.7rem;
    font-size: 1.15rem;
    font-weight: 620;
    letter-spacing: -0.01em;
  }

  .post__body :global(p) {
    margin-top: 1rem;
    color: var(--text-2);
    line-height: 1.75;
  }

  .post__body :global(p:first-child) {
    margin-top: 0;
  }

  .post__body :global(strong) {
    color: var(--text);
    font-weight: 620;
  }

  .post__body :global(a) {
    color: var(--accent-text);
  }

  .post__body :global(a:hover) {
    text-decoration: underline;
  }

  .post__body :global(ul),
  .post__body :global(ol) {
    margin-top: 1rem;
    padding-left: 1.3rem;
    color: var(--text-2);
    line-height: 1.75;
  }

  .post__body :global(li) {
    margin-top: 0.3rem;
  }

  .post__body :global(code) {
    font-family: var(--font-mono);
    font-size: 0.88em;
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.12em 0.4em;
  }

  .post__body :global(pre) {
    margin-top: 1.2rem;
    padding: 1rem 1.1rem;
    border-radius: 10px;
    border: 1px solid var(--border);
    background: var(--surface) !important;
    overflow-x: auto;
  }

  .post__body :global(pre code) {
    background: none;
    border: none;
    padding: 0;
  }

  .post__body :global(blockquote) {
    margin-top: 1.2rem;
    padding-left: 1.1rem;
    border-left: 2px solid var(--border-strong);
    color: var(--text-2);
    font-style: italic;
  }

  .post__body :global(hr) {
    margin-block: 2rem;
    border: none;
    border-top: 1px solid var(--border);
  }

  .post__foot {
    margin-top: 3.5rem;
    padding-top: 1.6rem;
    font-family: var(--font-mono);
    font-size: 0.88rem;
  }

  .post__foot a {
    color: var(--accent-text);
  }

  .post__foot a:hover {
    text-decoration: underline;
  }

  .post__nav {
    margin-top: 1.6rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .post__nav-link {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    color: inherit;
    text-decoration: none;
  }

  .post__nav-link--next {
    grid-column: 2;
    text-align: right;
  }

  .post__nav-label {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--muted);
  }

  .post__nav-title {
    font-size: 0.94rem;
    color: var(--accent-text);
  }

  .post__nav-link:hover .post__nav-title {
    text-decoration: underline;
  }

  @media (max-width: 560px) {
    .post__nav {
      grid-template-columns: 1fr;
    }

    .post__nav-link--next {
      grid-column: 1;
      text-align: left;
    }
  }
</style>

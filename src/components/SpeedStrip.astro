---
const points = [
  {
    k: 'native, not wrapped',
    title: 'Built with Tauri, not Electron',
    body: 'Most note apps ship an entire browser to draw their window. This one uses the one your Mac already has — so it opens like a system app, not a website.',
  },
  {
    k: 'rust under the hood',
    title: 'Heavy lifting in compiled code',
    body: 'Search, file access, and indexing run as native Rust — not JavaScript. Full-text search across a whole vault comes back before your finger leaves the key.',
  },
  {
    k: 'light by design',
    title: 'Megabytes, not memory hogs',
    body: 'A small binary and a light footprint. Keep it open all day next to everything else, and it never asks you to wait.',
  },
];
---

<section class="speed section hairline-top">
  <div class="container">
    <p class="tick-label" data-reveal>
      <span class="tick-accent">[why]</span> it feels instant
    </p>
    <h2 class="display speed__title" data-reveal style="--reveal-delay: 60ms">
      The name is the promise.
    </h2>
    <p class="speed__lede prose-max" data-reveal style="--reveal-delay: 110ms">
      "No lag" isn't a tagline we bolted on — it's the reason the app exists,
      and it's engineered in from the first line of code.
    </p>

    <div class="speed__grid">
      {
        points.map((p, i) => (
          <div class="speed__cell" data-reveal style={`--reveal-delay: ${i * 90}ms`}>
            <p class="tick-label speed__k">{p.k}</p>
            <h3>{p.title}</h3>
            <p>{p.body}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .speed__title {
    margin-top: 1.1rem;
    font-size: clamp(1.9rem, 4.2vw, 3rem);
  }

  .speed__lede {
    margin-top: 1.1rem;
    color: var(--text-2);
    font-size: 1.05rem;
  }

  .speed__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2.5rem;
    margin-top: 3.5rem;
  }

  .speed__cell {
    padding-top: 1.4rem;
    border-top: 1px solid var(--border-strong);
  }

  .speed__k {
    color: var(--accent-text);
  }

  .speed__cell h3 {
    margin-top: 0.8rem;
    font-size: 1.08rem;
    font-weight: 620;
    letter-spacing: -0.015em;
  }

  .speed__cell p:last-child {
    margin-top: 0.55rem;
    font-size: 0.92rem;
    color: var(--text-2);
  }

  @media (max-width: 820px) {
    .speed__grid {
      grid-template-columns: 1fr;
      gap: 1.8rem;
    }
  }
</style>

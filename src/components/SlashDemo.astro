---
// Slash-command demo: built-ins, then a custom command.
---

<div class="window" id="slash-demo">
  <div class="window__bar">
    <div class="window__dots"><span></span><span></span><span></span></div>
    <div class="window__title">standup.md — no lag mind</div>
  </div>
  <div class="slash__page demo-page" id="slash-page"></div>
</div>

<style>
  .slash__page {
    padding: 1.4rem 1.6rem;
    min-height: 14.5rem;
  }

  .slash__page :global(.tmpl) {
    color: var(--text-2);
  }

  .slash__page :global(.tmpl .b) {
    color: var(--text);
  }
</style>

<script>
  import { prefersReducedMotion, sleep, createSurface, runLoop } from '../scripts/demo';

  const page = document.getElementById('slash-page')!;
  const { clear, newLine, caretTo, typeIn } = createSurface(page);

  const TODAY = new Date().toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });

  interface Item {
    name: string;
    hint: string;
  }

  const ALL: Item[] = [
    { name: '/date', hint: 'insert date' },
    { name: '/time', hint: 'insert time' },
    { name: '/table', hint: 'insert table' },
    { name: '/standup', hint: 'custom · yours' },
  ];

  function menu(items: Item[], active: number): HTMLElement {
    const m = document.createElement('div');
    m.className = 'demo-menu';
    m.innerHTML = items
      .map(
        (it, i) =>
          `<div class="demo-menu__item${i === active ? ' is-active' : ''}"><span>${it.name}</span><span class="hint">${it.hint}</span></div>`
      )
      .join('');
    return m;
  }

  async function run() {
    clear();
    await sleep(500);

    const h = newLine('l-h2');
    caretTo(h);
    await typeIn(h, '', 'Standup');
    await sleep(300);

    // beat 1: a built-in — /date
    const l1 = newLine();
    caretTo(l1);
    const raw1 = await typeIn(l1, 'raw', '/');
    let m = menu(ALL, 0);
    page.appendChild(m);
    await sleep(400);
    await typeIn(l1, 'raw', 'date', 46);
    m.replaceWith((m = menu([ALL[0]], 0)));
    await sleep(520);

    m.remove();
    l1.querySelectorAll('.raw').forEach((r) => r.remove());
    caretTo(l1);
    await typeIn(l1, 'b', TODAY, 8);
    await sleep(700);

    // beat 2: your own command — /standup
    const l2 = newLine();
    caretTo(l2);
    await typeIn(l2, 'raw', '/sta', 46);
    m = menu([ALL[3]], 0);
    page.appendChild(m);
    await sleep(560);

    m.remove();
    l2.remove();
    for (const line of ['yesterday — shipped the graph view', 'today — polish wikilink autocomplete', 'blockers — none']) {
      const l = newLine('tmpl');
      const [head, rest] = line.split(' — ');
      l.innerHTML = `<span class="b">${head}</span> — ${rest}`;
      await sleep(120);
    }
    const tail = newLine();
    caretTo(tail);
    await sleep(4200);
  }

  if (prefersReducedMotion()) {
    page.innerHTML = `
      <div class="l l-h2">Standup</div>
      <div class="l"><span class="b">${TODAY}</span></div>
      <div class="l tmpl"><span class="b">yesterday</span> — shipped the graph view</div>
      <div class="l tmpl"><span class="b">today</span> — polish wikilink autocomplete</div>
      <div class="l tmpl"><span class="b">blockers</span> — none</div>`;
  } else {
    runLoop(page, run);
  }
</script>

---
import { site } from '../data/site';
---

<section class="final section hairline-top">
  <div class="container final__inner">
    <p class="tick-label" data-reveal>
      <span class="tick-accent">[ready?]</span> your move
    </p>
    <h2 class="display final__title" data-reveal style="--reveal-delay: 60ms">
      Stop waiting on<br />your note app<span class="final__dot">.</span>
    </h2>
    <p class="final__sub" data-reveal style="--reveal-delay: 110ms">
      Download it, open a vault, and type. You'll feel the difference in the
      first sentence.
    </p>
    <div class="final__cta" data-reveal style="--reveal-delay: 160ms">
      <a href={site.downloadUrl} class="keycap keycap--accent final__btn js-download" download>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 3v12m0 0 5-5m-5 5-5-5M4 21h16"></path>
        </svg>
        Download for macOS
      </a>
      <a href={site.discordUrl} target="_blank" rel="noopener" class="keycap">join the discord</a>
    </div>
    <p class="final__fine" data-reveal style="--reveal-delay: 200ms">
      free · {site.downloadPlatform} · v{site.version}
    </p>
  </div>
</section>

<style>
  .final {
    position: relative;
    text-align: center;
    overflow: hidden;
  }

  .final::before {
    content: '';
    position: absolute;
    inset: 30% 0 0;
    background-image: radial-gradient(var(--grid-dot) 1px, transparent 1px);
    background-size: 22px 22px;
    mask-image: radial-gradient(ellipse 60% 80% at 50% 100%, black 20%, transparent 75%);
    -webkit-mask-image: radial-gradient(ellipse 60% 80% at 50% 100%, black 20%, transparent 75%);
    pointer-events: none;
  }

  .final__inner {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .final__title {
    margin-top: 1.3rem;
    font-size: clamp(2.2rem, 6vw, 4rem);
  }

  .final__dot {
    color: var(--accent);
  }

  .final__sub {
    margin-top: 1.3rem;
    color: var(--text-2);
    max-width: 30em;
    text-wrap: pretty;
  }

  .final__cta {
    display: flex;
    gap: 0.9rem;
    margin-top: 2.2rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .final__btn {
    font-size: 1.05rem;
  }

  .final__fine {
    margin-top: 1.1rem;
    font-family: var(--font-mono);
    font-size: 0.74rem;
    color: var(--muted);
  }
</style>

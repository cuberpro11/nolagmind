---
import { site } from '../data/site';
---

<section class="final section hairline-top">
  <div class="container final__inner">
    <p class="tick-label" data-reveal>
      <span class="tick-accent">[ready?]</span> your move
    </p>
    <h2 class="display final__title" data-reveal style="--reveal-delay: 60ms">
      Stop waiting on<br />your note app<span class="final__dot">.</span>
    </h2>
    <p class="final__sub" data-reveal style="--reveal-delay: 110ms">
      Download it, open a vault, and type. You'll feel the difference in the
      first sentence.
    </p>
    <div class="final__cta" data-reveal style="--reveal-delay: 160ms">
      <a href={site.downloadUrl} class="keycap keycap--accent final__btn js-download" download>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 3v12m0 0 5-5m-5 5-5-5M4 21h16"></path>
        </svg>
        Download for macOS
      </a>
      <a href={site.discordUrl} target="_blank" rel="noopener" class="keycap keycap--discord">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M20.317 4.3698a19.7913 19.7913 0 00-4.8851-1.5152.0741.0741 0 00-.0785.0371c-.211.3753-.4447.8648-.6083 1.2495-1.8447-.2762-3.68-.2762-5.4868 0-.1636-.3933-.4058-.8742-.6177-1.2495a.077.077 0 00-.0785-.037 19.7363 19.7363 0 00-4.8852 1.515.0699.0699 0 00-.0321.0277C.5334 9.0458-.319 13.5799.0992 18.0578a.0824.0824 0 00.0312.0561c2.0528 1.5076 4.0413 2.4228 5.9929 3.0294a.0777.0777 0 00.0842-.0276c.4616-.6304.8731-1.2952 1.226-1.9942a.076.076 0 00-.0416-.1057c-.6528-.2476-1.2743-.5495-1.8722-.8923a.077.077 0 01-.0076-.1277c.1258-.0943.2517-.1923.3718-.2914a.0743.0743 0 01.0776-.0105c3.9278 1.7933 8.18 1.7933 12.0614 0a.0739.0739 0 01.0785.0095c.1202.099.246.1981.3728.2924a.077.077 0 01-.0066.1276 12.2986 12.2986 0 01-1.873.8914.0766.0766 0 00-.0407.1067c.3604.698.7719 1.3628 1.225 1.9932a.076.076 0 00.0842.0286c1.961-.6067 3.9495-1.5219 6.0023-3.0294a.077.077 0 00.0313-.0552c.5004-5.177-.8382-9.6739-3.5485-13.6604a.061.061 0 00-.0312-.0286zM8.02 15.3312c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9555-2.4189 2.157-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.9555 2.4189-2.1569 2.4189zm7.9748 0c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9554-2.4189 2.1569-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.946 2.4189-2.1568 2.4189Z"/>
        </svg>
        join the discord
      </a>
    </div>
    <p class="final__fine" data-reveal style="--reveal-delay: 200ms">
      free · {site.downloadPlatform} · v{site.version}
    </p>
  </div>
</section>

<style>
  .final {
    position: relative;
    text-align: center;
    overflow: hidden;
  }

  .final::before {
    content: '';
    position: absolute;
    inset: 30% 0 0;
    background-image: radial-gradient(var(--grid-dot) 1px, transparent 1px);
    background-size: 22px 22px;
    mask-image: radial-gradient(ellipse 60% 80% at 50% 100%, black 20%, transparent 75%);
    -webkit-mask-image: radial-gradient(ellipse 60% 80% at 50% 100%, black 20%, transparent 75%);
    pointer-events: none;
  }

  .final__inner {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .final__title {
    margin-top: 1.3rem;
    font-size: clamp(2.2rem, 6vw, 4rem);
  }

  .final__dot {
    color: var(--accent);
  }

  .final__sub {
    margin-top: 1.3rem;
    color: var(--text-2);
    max-width: 30em;
    text-wrap: pretty;
  }

  .final__cta {
    display: flex;
    gap: 0.9rem;
    margin-top: 2.2rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .final__btn {
    font-size: 1.05rem;
  }

  .final__fine {
    margin-top: 1.1rem;
    font-family: var(--font-mono);
    font-size: 0.74rem;
    color: var(--muted);
  }
</style>

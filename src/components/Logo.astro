---
// Keycap-with-bolt mark + wordmark, echoing the app icon.
---

<a href="/" class="logo" aria-label="No Lag Mind — home">
  <svg
    class="logo__mark"
    width="26"
    height="26"
    viewBox="0 0 64 64"
    aria-hidden="true"
  >
    <rect x="4" y="10" width="56" height="50" rx="13" class="logo__edge"></rect>
    <rect x="4" y="4" width="56" height="50" rx="13" class="logo__face"></rect>
    <path
      d="M37.5 9 L20 33.5 h10.5 L25.5 49 L44 25.5 H33.5 L37.5 9 Z"
      class="logo__bolt"></path>
  </svg>
  <span class="logo__word">nolagmind<span class="logo__cursor">_</span></span>
</a>

<style>
  .logo {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
  }

  .logo__edge {
    fill: color-mix(in srgb, var(--accent) 55%, black);
  }

  .logo__face {
    fill: var(--accent);
  }

  .logo__bolt {
    fill: #ffffff;
  }

  .logo__word {
    font-family: var(--font-mono);
    font-size: 0.95rem;
    font-weight: 500;
    letter-spacing: -0.01em;
  }

  .logo__cursor {
    color: var(--accent-text);
    animation: caret-blink 1.1s steps(1) infinite;
  }
</style>

---
import Logo from './Logo.astro';
import { site } from '../data/site';

const links = [
  { href: '/#features', label: 'features' },
  { href: '/#pricing', label: 'extras' },
  { href: '/changelog', label: 'changelog' },
  { href: '/blog', label: 'blog' },
  { href: '/docs', label: 'docs' },
];
---

<header class="nav-wrap">
  <div class="container nav">
    <Logo />

    <nav class="nav__links" aria-label="Main">
      {links.map((l) => <a href={l.href}>{l.label}</a>)}
    </nav>

    <div class="nav__actions">
      <button
        class="theme-toggle"
        id="theme-toggle"
        type="button"
        aria-label="Toggle color theme"
      >
        <svg class="theme-toggle__moon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
        </svg>
        <svg class="theme-toggle__sun" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="4"></circle>
          <path d="M12 2v2m0 16v2M4.93 4.93l1.41 1.41m11.32 11.32 1.41 1.41M2 12h2m16 0h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"></path>
        </svg>
      </button>

      <a
        href={site.downloadUrl}
        class="keycap keycap--quiet keycap--accent nav__download js-download"
        download
      >
        download
      </a>

      <button
        class="nav__burger"
        id="nav-burger"
        type="button"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="nav-mobile"
      >
        <span></span><span></span>
      </button>
    </div>
  </div>

  <div class="nav-mobile" id="nav-mobile" hidden>
    {links.map((l) => <a href={l.href}>{l.label}</a>)}
  </div>
</header>

<style>
  .nav-wrap {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--bg) 82%, transparent);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom: 1px solid var(--border);
  }

  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    height: 3.8rem;
  }

  .nav__links {
    display: flex;
    gap: 1.9rem;
    font-family: var(--font-mono);
    font-size: 0.84rem;
  }

  .nav__links a {
    color: var(--text-2);
    transition: color 130ms var(--ease-out);
  }

  .nav__links a:hover {
    color: var(--text);
  }

  .nav__actions {
    display: flex;
    align-items: center;
    gap: 0.8rem;
  }

  .theme-toggle {
    display: grid;
    place-items: center;
    width: 2.1rem;
    height: 2.1rem;
    border-radius: 0.55rem;
    border: 1px solid var(--border);
    color: var(--text-2);
    transition: color 130ms, border-color 130ms;
  }

  .theme-toggle:hover {
    color: var(--text);
    border-color: var(--border-strong);
  }

  .theme-toggle__sun {
    display: none;
  }

  :global([data-theme='light']) .theme-toggle__sun {
    display: block;
  }

  :global([data-theme='light']) .theme-toggle__moon {
    display: none;
  }

  .nav__burger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 2.1rem;
    height: 2.1rem;
    border-radius: 0.55rem;
    border: 1px solid var(--border);
  }

  .nav__burger span {
    display: block;
    height: 1.5px;
    margin-inline: 7px;
    background: var(--text);
    transition: transform 180ms var(--ease-out);
  }

  .nav__burger[aria-expanded='true'] span:first-child {
    transform: translateY(3.25px) rotate(45deg);
  }

  .nav__burger[aria-expanded='true'] span:last-child {
    transform: translateY(-3.25px) rotate(-45deg);
  }

  .nav-mobile {
    display: none;
    flex-direction: column;
    padding: 0.6rem var(--page-pad) 1.1rem;
    border-bottom: 1px solid var(--border);
    font-family: var(--font-mono);
    font-size: 0.95rem;
  }

  .nav-mobile a {
    padding: 0.65rem 0;
    color: var(--text-2);
    border-bottom: 1px solid var(--border);
  }

  .nav-mobile a:last-child {
    border-bottom: none;
  }

  @media (max-width: 720px) {
    .nav__links {
      display: none;
    }

    .nav__burger {
      display: flex;
    }

    .nav-mobile:not([hidden]) {
      display: flex;
    }
  }
</style>

<script>
  const toggle = document.getElementById('theme-toggle');
  toggle?.addEventListener('click', () => {
    const root = document.documentElement;
    const next = root.dataset.theme === 'light' ? 'dark' : 'light';
    root.dataset.theme = next;
    localStorage.setItem('nlm-theme', next);
  });

  const burger = document.getElementById('nav-burger');
  const mobile = document.getElementById('nav-mobile');
  burger?.addEventListener('click', () => {
    const open = burger.getAttribute('aria-expanded') === 'true';
    burger.setAttribute('aria-expanded', String(!open));
    if (mobile) mobile.hidden = open;
  });
  mobile?.addEventListener('click', (e) => {
    if ((e.target as HTMLElement).tagName === 'A') {
      burger?.setAttribute('aria-expanded', 'false');
      mobile.hidden = true;
    }
  });
</script>

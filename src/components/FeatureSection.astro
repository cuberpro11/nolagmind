---
interface Props {
  num: string;
  kicker: string;
  title: string;
  body: string[];
  flip?: boolean;
  id?: string;
}

const { num, kicker, title, body, flip = false, id } = Astro.props;
---

<section class:list={['feature', 'section', 'hairline-top', { 'feature--flip': flip }]} id={id}>
  <div class="container feature__grid">
    <div class="feature__copy" data-reveal>
      <p class="tick-label">
        <span class="tick-accent">[{num}]</span> {kicker}
      </p>
      <h2 class="display feature__title">{title}</h2>
      {body.map((p) => <p class="feature__body" set:html={p} />)}
    </div>
    <div class="feature__demo" data-reveal style="--reveal-delay: 120ms">
      <slot />
    </div>
  </div>
</section>

<style>
  .feature__grid {
    display: grid;
    grid-template-columns: minmax(0, 5fr) minmax(0, 6fr);
    gap: clamp(2.5rem, 6vw, 5rem);
    align-items: center;
  }

  .feature--flip .feature__grid {
    grid-template-columns: minmax(0, 6fr) minmax(0, 5fr);
  }

  .feature--flip .feature__copy {
    order: 2;
  }

  .feature--flip .feature__demo {
    order: 1;
  }

  .feature__title {
    margin-top: 1.1rem;
    font-size: clamp(1.7rem, 3.6vw, 2.5rem);
  }

  .feature__body {
    margin-top: 1.1rem;
    color: var(--text-2);
    font-size: 1rem;
    max-width: 32em;
    text-wrap: pretty;
  }

  .feature__body :global(strong) {
    color: var(--text);
    font-weight: 600;
  }

  .feature__body :global(.kbd) {
    color: var(--text);
  }

  @media (max-width: 880px) {
    .feature__grid,
    .feature--flip .feature__grid {
      grid-template-columns: 1fr;
      gap: 2.2rem;
    }

    .feature--flip .feature__copy {
      order: 1;
    }

    .feature--flip .feature__demo {
      order: 2;
    }
  }
</style>
